From 76c4114f1a02358e0195f7e59397552029897e1f Mon Sep 17 00:00:00 2001
From: Mio <mio@mio19.uk>
Date: Sat, 21 Feb 2026 22:38:01 +1100
Subject: [PATCH] husky: increase default zram and writeback sizes

---
 vendor-skels/google_devices/husky/sysprop/product.prop | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/vendor-skels/google_devices/husky/sysprop/product.prop b/vendor-skels/google_devices/husky/sysprop/product.prop
index 9cde85f6..50a73bf3 100644
--- a/vendor-skels/google_devices/husky/sysprop/product.prop
+++ b/vendor-skels/google_devices/husky/sysprop/product.prop
@@ -39,8 +39,8 @@ mm.zram.maintenance.first_delay_seconds=86400
 mm.zram.maintenance.periodic_delay_seconds=86400
 mmd.zram.comp_algorithm=lz77eh
 mmd.zram.enabled=true
-mmd.zram.size=50%
-mmd.zram.writeback.device_size=1073741824
+mmd.zram.size=100%
+mmd.zram.writeback.device_size=8589934592
 mmd.zram.writeback.enabled=true
 mmd.zram.writeback.huge_idle.enabled=false
 mmd.zram.writeback.idle.enabled=true
-- 
2.52.0

