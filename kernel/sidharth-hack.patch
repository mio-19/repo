---
 .../platform/pixel/pixel_gpu_dvfs_metrics.c               | 8 ++++++++
 .../mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c    | 8 ++++++++
 2 files changed, 16 insertions(+)

diff --git a/private/google-modules/gpu/borr_mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c b/private/google-modules/gpu/borr_mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c
index bfb022f71..ff84e2283 100644
--- a/private/google-modules/gpu/borr_mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c
+++ b/private/google-modules/gpu/borr_mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c
@@ -277,10 +277,18 @@ int gpu_dvfs_kctx_init(struct kbase_context *kctx)
 
 	/* Get UID from task_struct */
 	pid = find_get_pid(kctx->kprcs->tgid);
+	if (pid) {
 	task = get_pid_task(pid, PIDTYPE_TGID);
+	if (task) {
 	uid = task->cred->uid;
 	put_task_struct(task);
+	} else {
+	uid = current_uid();
+	}
 	put_pid(pid);
+	} else {
+	uid = current_uid();
+	}
 	uid_hash = gpu_dvfs_hash_uid_stats(__kuid_val(uid));
 
 	mutex_lock(&kbdev->kctx_list_lock);
diff --git a/private/google-modules/gpu/mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c b/private/google-modules/gpu/mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c
index bfb022f71..ff84e2283 100644
--- a/private/google-modules/gpu/mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c
+++ b/private/google-modules/gpu/mali_kbase/platform/pixel/pixel_gpu_dvfs_metrics.c
@@ -277,10 +277,18 @@ int gpu_dvfs_kctx_init(struct kbase_context *kctx)
 
 	/* Get UID from task_struct */
 	pid = find_get_pid(kctx->kprcs->tgid);
+	if (pid) {
 	task = get_pid_task(pid, PIDTYPE_TGID);
+	if (task) {
 	uid = task->cred->uid;
 	put_task_struct(task);
+	} else {
+	uid = current_uid();
+	}
 	put_pid(pid);
+	} else {
+	uid = current_uid();
+	}
 	uid_hash = gpu_dvfs_hash_uid_stats(__kuid_val(uid));
 
 	mutex_lock(&kbdev->kctx_list_lock);
