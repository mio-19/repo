From 188d5f3c54a26aa8f67eca95e5118dfd552be175 Mon Sep 17 00:00:00 2001
From: Mio <mio@mio19.uk>
Date: Mon, 8 Jun 2026 14:19:35 +1000
Subject: [PATCH] git-no-doInstallCheck

---
 pkgs/by-name/gi/git/package.nix | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/pkgs/by-name/gi/git/package.nix b/pkgs/by-name/gi/git/package.nix
index bda0344badb9..478281b06289 100644
--- a/pkgs/by-name/gi/git/package.nix
+++ b/pkgs/by-name/gi/git/package.nix
@@ -49,7 +49,7 @@
   withSsh ? false,
   sysctl,
   deterministic-host-uname, # trick Makefile into targeting the host platform when cross-compiling
-  doInstallCheck ? !stdenv.hostPlatform.isDarwin, # extremely slow on darwin
+  doInstallCheck ? false,
   tests,
   testers,
   rustSupport ? lib.meta.availableOn stdenv.hostPlatform rustc,
