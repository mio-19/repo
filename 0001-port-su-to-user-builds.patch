diff --git a/prebuilts/api/202504/private/adbd.te b/prebuilts/api/202504/private/adbd.te
index 138c8f51a..6db2a8a73 100644
--- a/prebuilts/api/202504/private/adbd.te
+++ b/prebuilts/api/202504/private/adbd.te
@@ -88,10 +88,8 @@ set_prop(adbd, adbd_tradeinmode_prop)
 set_prop(adbd, ctl_mdnsd_prop)
 
 # Read device's overlayfs related properties and files
-userdebug_or_eng(`
-  get_prop(adbd, persistent_properties_ready_prop)
-  r_dir_file(adbd, sysfs_dt_firmware_android)
-')
+get_prop(adbd, persistent_properties_ready_prop)
+r_dir_file(adbd, sysfs_dt_firmware_android)
 
 # Run /system/bin/bu
 allow adbd system_file:file rx_file_perms;
diff --git a/prebuilts/api/32.0/private/adbd.te b/prebuilts/api/32.0/private/adbd.te
index 42739957e..20e552a43 100644
--- a/prebuilts/api/32.0/private/adbd.te
+++ b/prebuilts/api/32.0/private/adbd.te
@@ -7,10 +7,8 @@ init_daemon_domain(adbd)
 
 domain_auto_trans(adbd, shell_exec, shell)
 
-userdebug_or_eng(`
-  allow adbd self:process setcurrent;
-  allow adbd su:process dyntransition;
-')
+allow adbd self:process setcurrent;
+allow adbd su:process dyntransition;
 
 # When 'adb shell' is executed in recovery mode, adbd explicitly
 # switches into shell domain using setcon() because the shell executable
@@ -114,10 +112,8 @@ get_prop(adbd, test_harness_prop)
 get_prop(adbd, system_adbd_prop)
 
 # Read device's overlayfs related properties and files
-userdebug_or_eng(`
-  get_prop(adbd, persistent_properties_ready_prop)
-  r_dir_file(adbd, sysfs_dt_firmware_android)
-')
+get_prop(adbd, persistent_properties_ready_prop)
+r_dir_file(adbd, sysfs_dt_firmware_android)
 
 # Run /system/bin/bu
 allow adbd system_file:file rx_file_perms;
@@ -231,4 +227,4 @@ allow adbd apex_info_file:file r_file_perms;
 # transitions to the shell domain (except when it crashes). In particular, we
 # never want to see a transition from adbd to su (aka "adb root")
 neverallow adbd { domain -crash_dump -shell }:process transition;
-neverallow adbd { domain userdebug_or_eng(`-su') recovery_only(`-shell') }:process dyntransition;
+neverallow adbd { domain -su recovery_only(`-shell') }:process dyntransition;
diff --git a/prebuilts/api/32.0/private/app.te b/prebuilts/api/32.0/private/app.te
index 30c76d330..22fffee44 100644
--- a/prebuilts/api/32.0/private/app.te
+++ b/prebuilts/api/32.0/private/app.te
@@ -52,9 +52,9 @@ neverallow appdomain system_server:udp_socket {
 # Exception for crash_dump to allow for app crash reporting.
 # Exception for renderscript binaries (/system/bin/bcc, /system/bin/ld.mc)
 # to allow renderscript to create privileged executable files.
-neverallow { appdomain -shell userdebug_or_eng(`-su') }
+neverallow { appdomain -shell -su }
     { domain -appdomain -crash_dump -rs }:process { transition };
-neverallow { appdomain -shell userdebug_or_eng(`-su') }
+neverallow { appdomain -shell -su }
     { domain -appdomain }:process { dyntransition };
 
 # Don't allow regular apps access to storage configuration properties.
diff --git a/prebuilts/api/32.0/private/app_zygote.te b/prebuilts/api/32.0/private/app_zygote.te
index 004c10844..0f65b9474 100644
