+++ b/prebuilts/api/32.0/private/app_zygote.te
@@ -148,7 +148,7 @@ neverallow app_zygote {
   -app_zygote
   -logd
   -system_server
-  userdebug_or_eng(`-su')
+  -su
   userdebug_or_eng(`-heapprofd')
   userdebug_or_eng(`-traced_perf')
 }:unix_dgram_socket *;
@@ -156,7 +156,7 @@ neverallow app_zygote {
 neverallow app_zygote {
   domain
   -app_zygote
-  userdebug_or_eng(`-su')
+  -su
   userdebug_or_eng(`-heapprofd')
   userdebug_or_eng(`-traced_perf')
 }:unix_stream_socket *;
diff --git a/prebuilts/api/32.0/private/domain.te b/prebuilts/api/32.0/private/domain.te
index b91d36d85..254d5f69c 100644
--- a/prebuilts/api/32.0/private/domain.te
+++ b/prebuilts/api/32.0/private/domain.te
@@ -2,7 +2,7 @@
 # This occurs when the process crashes.
 # We do not apply this to the su domain to avoid interfering with
 # tests (b/114136122)
-domain_auto_trans({ domain userdebug_or_eng(`-su') }, crash_dump_exec, crash_dump);
+domain_auto_trans({ domain -su }, crash_dump_exec, crash_dump);
 allow domain crash_dump:process sigchld;
 
 # Allow every process to check the heapprofd.enable properties to determine
@@ -231,7 +231,7 @@ neverallow {
     with_asan(`-asan_extract')
     -iorap_prefetcherd
     -shell
-    userdebug_or_eng(`-su')
+    -su
     -system_server_startup # for memfd backed executable regions
     -app_zygote
     -webview_zygote
@@ -446,7 +446,7 @@ full_treble_only(`
     -logd # Logging by writing to logd Unix domain socket is public API
     -netd # netdomain needs this
     -mdnsd # netdomain needs this
-    userdebug_or_eng(`-su') # communications with su are permitted only on userdebug or eng builds
+    -su # communications with su are permitted only on userdebug or eng builds
     -init
     -tombstoned # linker to tombstoned
     userdebug_or_eng(`-heapprofd')
