--- a/src/com/google/android/settings/display/HuskyHighEmissionFrequencyPreferenceController.kt
+++ b/src/com/google/android/settings/display/HuskyHighEmissionFrequencyPreferenceController.kt
@@ -0,0 +1,73 @@
+package com.google.android.settings.display
+
+import android.content.Context
+import android.os.Build
+import android.os.SystemProperties
+import android.text.TextUtils
+import android.util.Log
+import androidx.preference.ListPreference
+import androidx.preference.Preference
+import androidx.preference.PreferenceScreen
+import com.android.settings.R
+import com.android.settings.core.BasePreferenceController
+
+class HuskyHighEmissionFrequencyPreferenceController(context: Context, prefKey: String) :
+    BasePreferenceController(context, prefKey), Preference.OnPreferenceChangeListener {
+    private companion object {
+        const val TAG = "HuskyHighEmissionFrequencyPreferenceController"
+        const val PROPERTY = "persist.sys.husky_high_emission_frequency_mode"
+        const val DEFAULT_VALUE = "zero"
+    }
+
+    private val entryValues =
+        mContext.resources.getStringArray(R.array.husky_high_emission_frequency_values)
+
+    override fun getAvailabilityStatus(): Int =
+        if (Build.DEVICE == "husky") AVAILABLE else UNSUPPORTED_ON_DEVICE
+
+    override fun displayPreference(screen: PreferenceScreen) {
+        super.displayPreference(screen)
+        screen.findPreference<ListPreference>(preferenceKey)?.onPreferenceChangeListener = this
+    }
+
+    override fun updateState(preference: Preference) {
+        val listPreference = preference as ListPreference
+        val value = getCurrentValue()
+        listPreference.value = value
+        listPreference.summary = listPreference.entry
+    }
+
+    override fun onPreferenceChange(preference: Preference, newValue: Any): Boolean {
+        val listPreference = preference as ListPreference
+        val value = newValue.toString()
+
+        if (!entryValues.contains(value)) {
+            return false
+        }
+
+        return try {
+            Log.i(TAG, "Setting $PROPERTY to $value")
+            SystemProperties.set(PROPERTY, value)
+            val appliedValue = SystemProperties.get(PROPERTY, DEFAULT_VALUE)
+            Log.i(TAG, "Read back $PROPERTY as $appliedValue")
+            listPreference.value = value
+            listPreference.summary = listPreference.entry
+            true
+        } catch (e: RuntimeException) {
+            Log.e(TAG, "Failed to update husky high emission frequency mode", e)
+            false
+        }
+    }
+
+    private fun getCurrentValue(): String {
+        return try {
+            val value = SystemProperties.get(PROPERTY, DEFAULT_VALUE)
+            if (entryValues.any { TextUtils.equals(it, value) }) value else DEFAULT_VALUE
+        } catch (e: RuntimeException) {
+            Log.e(TAG, "Failed to read husky high emission frequency mode", e)
+            DEFAULT_VALUE
+        }
+    }
+
+    override fun getSliceHighlightMenuRes(): Int = R.string.menu_key_display
+}
