From 65e71b22f585677f8602d6acff68e58a01977763 Mon Sep 17 00:00:00 2001
From: Mio <mio@mio19.uk>
Date: Sat, 21 Feb 2026 22:41:02 +1100
Subject: [PATCH] akita: increase default zram and set writeback to 4G

---
 vendor-skels/google_devices/akita/sysprop/product.prop | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/vendor-skels/google_devices/akita/sysprop/product.prop b/vendor-skels/google_devices/akita/sysprop/product.prop
index dede7aae..cd7ee0b9 100644
--- a/vendor-skels/google_devices/akita/sysprop/product.prop
+++ b/vendor-skels/google_devices/akita/sysprop/product.prop
@@ -38,8 +38,8 @@ mm.zram.maintenance.first_delay_seconds=86400
 mm.zram.maintenance.periodic_delay_seconds=86400
 mmd.zram.comp_algorithm=lz77eh
 mmd.zram.enabled=true
-mmd.zram.size=50%
-mmd.zram.writeback.device_size=1073741824
+mmd.zram.size=100%
+mmd.zram.writeback.device_size=4294967296
 mmd.zram.writeback.enabled=true
 mmd.zram.writeback.huge_idle.enabled=false
 mmd.zram.writeback.idle.enabled=true
-- 
2.52.0

