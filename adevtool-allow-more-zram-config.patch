@@ -116,8 +116,14 @@ sysprop_inclusions:
   - mmd.zram.comp_algorithm = lz77eh
   - mmd.zram.enabled = true
   - mmd.zram.size = 3221225472
+  - mmd.zram.size = 8589934592
+  - mmd.zram.size = 12884901888
   - mmd.zram.size = 50%
+  - mmd.zram.size = 75%
+  - mmd.zram.size = 100%
   - mmd.zram.writeback.device_size = 1073741824
