 config/device/common/sysprop-inclusion.yml | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/config/device/common/sysprop-inclusion.yml b/config/device/common/sysprop-inclusion.yml
index 958f25db..8d6517fe 100644
