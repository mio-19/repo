From 9f61464383a0cb401bd81020180aacfbeee03ae3 Mon Sep 17 00:00:00 2001
From: Mio <mio@mio19.uk>
Date: Fri, 27 Mar 2026 22:38:21 +1100
Subject: [PATCH] always show vanadium

---
 app/src/main/java/app/grapheneos/apps/core/Repo.kt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/app/src/main/java/app/grapheneos/apps/core/Repo.kt b/app/src/main/java/app/grapheneos/apps/core/Repo.kt
index a4d789d..81ece6f 100644
--- a/app/src/main/java/app/grapheneos/apps/core/Repo.kt
+++ b/app/src/main/java/app/grapheneos/apps/core/Repo.kt
@@ -556,7 +556,7 @@ private class ComplexDependency(string: String) {
 
 private fun checkStaticDeps(json: JSONObject, dependentManifestPkgName: String, repo: Repo): Boolean {
     json.optJSONArray("supportedDevices")?.asStringList()?.let { devices ->
-        if (!devices.contains(Build.DEVICE)) {
+        if (!dependentManifestPkgName.contains("vanadium") && !devices.contains(Build.DEVICE)) {
             return false
         }
     }
